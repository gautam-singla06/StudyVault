{
  "name": "studyvault",
  "version": "1.0.0",
  "private": true,
  "description": "StudyVault - Electron + React + Tailwind + SQLite desktop app",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "npm run build:electron && wait-on http://127.0.0.1:5173 dist-electron/main.js dist-electron/preload.js && set ELECTRON_RUN_AS_NODE=&& electron .",
    "build": "tsc -p tsconfig.json && vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "package": "npm run build && electron-builder --win portable",
    "preview": "vite preview",
    "start": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run package"
  },
  "dependencies": {
    "sql.js": "^1.13.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.0.4",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.studyvault.app",
    "productName": "StudyVault",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": "portable",
      "artifactName": "StudyVault.${ext}",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
